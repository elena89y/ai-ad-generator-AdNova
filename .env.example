# 데이터베이스 세팅 예시
DATABASE_URL=sqlite:///./data/app.db
# 관리자 인증 정보 전용 DB (일반 사용자 DB와 분리)
ADMIN_DATABASE_URL=sqlite:///./data/admin.db
DB_HOST=localhost
DB_PORT=5432
DB_USER=myuser
DB_PASSWORD=

SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# 최초 관리자 계정 생성용(운영에서는 반드시 강한 비밀번호 사용)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@adnova.local
# 관리자 TOTP 비밀키 암호화용 Fernet 키. 운영에서는 SECRET_KEY와 별도로 설정
ADMIN_TOTP_ENCRYPTION_KEY=

# AI 서비스 API 키 예시
OPENAI_API_KEY=your_openai_api_key_here

# 사진 게이트+상품 분석을 Vision 1회로 통합하고 asset별로 재사용 (기본 off)
UNIFIED_ANALYSIS=0

# Hugging Face 공용 모델 캐시(선택): GCP VM에서 팀원별 중복 다운로드 방지
# 토큰 값은 env 에 직접 넣지 말고, 권한 제한된 파일 경로만 공유한다.
HF_HUB_CACHE=/opt/adnova/models/hub
HF_TOKEN_PATH=/opt/adnova/secrets/hf_token
U2NET_HOME=/opt/adnova/models/u2net

# 결정론적 스타일 색 마감. 실제 6종 이미지 게이트 승인 전에는 off 유지.
STYLE_FINISH=0
STYLE_FINISH_STRENGTH=0.6

# social-auth 연동
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FRONTEND_URL=
SESSION_SECRET_KEY=your-session-secret-key-here

# Langfuse 트레이싱 (Settings > API Keys 에서 발급). 비워두면 트레이싱 없이 정상 동작(app/core/observability.py 참고)
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com  # US: https://us.cloud.langfuse.com, 자체호스팅이면 해당 URL
