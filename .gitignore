# ====== 보안 및 환경변수 ======
.env
.env.local
.env.*.local
# ====== 파이썬 가상환경 및 캐시 ======
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
# ====== 데이터베이스 및 OS 임시 파일 ======
*.db
.DS_Store
Thumbs.db
# ====== 개발 툴 세팅 ======
.vscode/
.idea/
# ====== 프로젝트 특정 데이터 (구조 유지용 .gitkeep은 예외) ======
backend/uploads/*
backend/processed/*
backend/results/*
backend/temp_uploads/*
# AI 생성 결과물(이미지·검증 로그)은 backend/results/ai/ 에 저장 — git 업로드 금지
backend/results/ai/
# 오버레이용 폰트(OFL) — scripts/download_fonts.py 로 받음, repo 미포함
!backend/assets/fonts/
!backend/uploads/.gitkeep
!backend/processed/.gitkeep
!backend/results/.gitkeep
install_gpu_driver.py
# ====== 로컬 테스트 및 임시 스크립트 ======
*_test.py
fetch*.py
b_bg_compare.py
flux_only.py
lraum_v2.py
route_full.py
# v2 하네스 실행 산출물 (원장은 VM 생성, 코드·매니페스트는 추적)
backend/experiments/runs.jsonl
backend/experiments/report.md
backend/experiments/audit.jsonl

# 코드 백업 파일 (git 이력이 원본 — .bak 는 추적 안 함)
*.bak
*.bak.*

# ====== 실험 산출물 아카이브 (GCP 정리 재발 방지, 2026-07-21) ======
# 실험 번들·스크래치 tar 는 레포에 커밋 금지 — 서버로 재업로드/디스크 재점유 방지.
# (광고 산출물·업로드는 위 backend/results·uploads 규칙이 이미 커버)
*.tar
*.tar.gz
*.tgz
